# J-Bot (Everyone's Jarvis) configuration
# Copy to ~/.jbot/config.yaml and edit

bot:
  name: "jbot"
  trigger: "@jbot"
  emoji: "🤖"

teams:
  chat_ids:
    - "19:your-chat-id@thread.v2"
  trigger: "@jbot"
  poll_interval: 60  # seconds

claude:
  dispatcher_model: "sonnet"
  worker_model: "sonnet"
  max_concurrent: 5
  session_timeout: 86400  # 24 hours
  permission_mode: "auto"
  default_cwd: "~"

security:
  allowed_users:
    - "you@nvidia.com"
  admin_users:
    - "you@nvidia.com"

storage:
  db_path: "~/.jbot/jbot.db"

logging:
  level: "INFO"
  file: "~/.jbot/jbot.log"
